<configure
    xmlns="http://namespaces.zope.org/zope"
    xmlns:five="http://namespaces.zope.org/five"
    xmlns:i18n="http://namespaces.zope.org/i18n"
    xmlns:genericsetup="http://namespaces.zope.org/genericsetup"
    i18n_domain="PloneMeeting">

 <include package="zope.component" file="meta.zcml" />

    <subscriber for="plonemeeting.core.interfaces.IMeetingItem
                     plonemeeting.core.interfaces.IItemListTypeChangedEvent"
                handler=".tests.events.onItemListTypeChanged"/>

    <subscriber for="plonemeeting.core.interfaces.IMeetingItem
                     plonemeeting.core.interfaces.IItemLocalRolesUpdatedEvent"
                handler=".tests.events.onItemLocalRolesUpdated"/>

    <subscriber for="plonemeeting.core.content.meeting.IMeeting
                     plonemeeting.core.interfaces.IMeetingLocalRolesUpdatedEvent"
                handler=".tests.events.onMeetingLocalRolesUpdated"/>

</configure>
