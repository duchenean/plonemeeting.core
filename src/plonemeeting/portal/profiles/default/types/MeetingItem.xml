<?xml version="1.0"?>
<object name="MeetingItem" meta_type="Dexterity FTI" i18n:domain="PloneMeeting"
   xmlns:i18n="http://xml.zope.org/namespaces/i18n" purge="True">
 <property name="title" i18n:translate="">MeetingItem</property>
 <property name="description" i18n:translate=""></property>
 <property name="i18n_domain">plonemeeting.portal</property>
 <property name="icon_expr">string:${portal_url}/MeetingItem.png</property>
 <property name="factory">meetingitem</property>
 <property name="add_view_expr">string:${folder_url}/++add++MeetingItem</property>
 <property name="link_target"></property>
 <property name="immediate_view">view</property>
 <property name="global_allow">False</property>
 <property name="filter_content_types">True</property>
 <property name="allowed_content_types">
  <element value="meetingadvice"/>
  <element value="Image"/>
  <element value="annex"/>
  <element value="annexDecision"/>
 </property>
 <property name="allow_discussion">False</property>
 <property name="default_view">view</property>
 <property name="view_methods">
  <element value="view"/>
 </property>
 <property name="default_view_fallback">False</property>
 <property name="schema_policy">schema_policy_meetingitem</property>
 <property name="klass">plonemeeting.portal.content.meetingitem.MeetingItem</property>
 <property name="behaviors">
  <element value="plone.app.lockingbehavior.behaviors.ILocking" />
 </property>
 <property name="schema"></property>
 <property name="model_source">
     &lt;model xmlns="http://namespaces.plone.org/supermodel/schema"&gt;
       &lt;schema/&gt;
     &lt;/model&gt;
 </property>

 <alias from="(Default)" to="(dynamic view)"/>
 <alias from="edit" to="@@edit"/>
 <alias from="sharing" to="@@sharing"/>
 <alias from="view" to="(selected layout)"/>

 <action title="View" action_id="view" category="object" condition_expr=""
    description="" icon_expr="" link_target="" url_expr="string:${object_url}"
    visible="True">
  <permission value="View"/>
 </action>
 <action title="Edit" action_id="edit" category="object"
    condition_expr="not:object/@@plone_lock_info/is_locked_for_current_user|python:True"
    description="" icon_expr="" link_target=""
    url_expr="string:${object_url}/edit" visible="True">
  <permission value="Modify portal content"/>
 </action>
 <action title="Annexes" i18n:attributes="title" action_id="annexes" category="object"
    condition_expr="python: portal.portal_plonemeeting.showAnnexesTab(here)"
    description="" icon_expr="" link_target=""
    url_expr="string:${object_url}/@@categorized-annexes" visible="True">
  <permission value="View"/>
 </action>
 <action title="Duplicate" i18n:attributes="title" action_id="duplicate" category="object_buttons"
    condition_expr="python:object.showDuplicateItemAction()"
    description="" icon_expr="string:${portal_url}/copy_icon.gif" link_target=""
    url_expr="string:${object_url}/@@item_duplicate_form" visible="True">
  <permission value="Copy or Move"/>
 </action>
 <action title="Export PDF" i18n:attributes="title" action_id="export_pdf" category="object_buttons"
    condition_expr="python:object.show_export_pdf_action()"
    description="" icon_expr="string:${portal_url}/++resource++collective.documentgenerator/pdf.svg"
    link_target="" url_expr="string:${object_url}/@@item-export-pdf-form" visible="True">
  <permission value="View"/>
 </action>
</object>
