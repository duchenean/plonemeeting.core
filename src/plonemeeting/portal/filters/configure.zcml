<configure
    xmlns="http://namespaces.zope.org/zope"
    xmlns:zcml="http://namespaces.zope.org/zcml"
    xmlns:browser="http://namespaces.zope.org/browser">

  <adapter
    provides="plone.outputfilters.interfaces.IFilter"
    name="css_transforms"
    for="plonemeeting.portal.interfaces.IMeetingContent
         *"
    factory=".css_transforms.CssTransformer"
    zcml:condition="installed plonemeeting.portal" />

</configure>
